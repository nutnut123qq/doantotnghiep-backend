{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{CorrelationId}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "StockInvestment.Api"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=stock_investment;Username=postgres;Password=YOUR_PASSWORD_HERE",
    "Redis": "localhost:6379",
    "RabbitMQ": "amqp://guest:guest@localhost:5672/"
  },
  "RabbitMQ": {
    "Enabled": false
  },
  "JWT": {
    "Secret": "YOUR_JWT_SECRET_KEY_MIN_32_CHARACTERS_LONG_CHANGE_THIS",
    "Issuer": "StockInvestmentApi",
    "Audience": "StockInvestmentClient"
  },
  "AIService": {
    "BaseUrl": "http://localhost:8000",
    "Url": "http://localhost:8000"
  },
  "AnalystContext": {
    "ApiKey": ""
  },
  "StockAnalyst": {
    "Enabled": false,
    "BaseUrl": "",
    "TimeoutSeconds": 180
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "SecurityHeaders": {
    "XFrameOptions": "DENY",
    "ReferrerPolicy": "strict-origin-when-cross-origin",
    "HstsMaxAge": 31536000,
    "HstsIncludeSubDomains": true,
    "HstsPreload": false,
    "ContentSecurityPolicy": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https:; frame-ancestors 'none';",
    "PermissionsPolicy": "geolocation=(), microphone=(), camera=()"
  },
  "RateLimiting": {
    "GlobalRequestsPerMinute": 100,
    "AuthRequestsPerMinute": 15,
    "ApiRequestsPerMinute": 60,
    "EnableRateLimiting": true
  },
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": "587",
    "SenderEmail": "noreply@stockinvestment.com",
    "SenderName": "Stock Investment Platform",
    "Username": "",
    "Password": "",
    "EnableSsl": "true",
    "BaseUrl": "http://localhost:3000"
  },
  "NotificationChannels": {
    "Telegram": {
      "BotToken": "YOUR_TELEGRAM_BOT_TOKEN_HERE"
    }
  },
  "EventCrawler": {
    "EnableCafeF": false,
    "EnableVietStock": false
  },
  "Features": {
    "AllowMockMarketData": false
  },
  "BackgroundJobs": {
    "EnableDistributedLock": true
  },
  "Notifications": {
    "EnableExternalChannels": false
  },
  "NewsIngestion": {
    "InitialDelaySeconds": 10,
    "PollMinutes": 10,
    "MaxArticlesPerRun": 80,
    "BlockedUrlPathSegments": [
      "phap-luat",
      "giai-tri",
      "the-thao",
      "suc-khoe",
      "doi-song",
      "giao-duc",
      "van-hoa"
    ],
    "Sources": [
      {
        "Name": "CafeF",
        "Kind": "HtmlBuiltin",
        "HtmlTemplate": "CafeF",
        "MaxItems": 18
      },
      {
        "Name": "VietStock",
        "Kind": "HtmlBuiltin",
        "HtmlTemplate": "VietStock",
        "MaxItems": 18
      },
      {
        "Name": "VnExpress-RSS",
        "Kind": "Rss",
        "Url": "https://vnexpress.net/rss/kinh-doanh/chung-khoan.rss",
        "MaxItems": 25
      },
      {
        "Name": "TuoiTre-RSS",
        "Kind": "Rss",
        "Url": "https://tuoitre.vn/rss/chung-khoan.rss",
        "MaxItems": 20
      },
      {
        "Name": "VietnamNet-RSS",
        "Kind": "Rss",
        "Url": "https://vietnamnet.vn/rss/chung-khoan.rss",
        "MaxItems": 20
      }
    ]
  },
  "FinancialIngestion": {
    "Enabled": true,
    "InitialDelaySeconds": 30,
    "PollMinutes": 10,
    "TopTickersPerRun": 15,
    "MaxReportsPerSymbol": 10,
    "AdditionalSymbols": [ "VIC" ]
  },
  "EventIngestion": {
    "Enabled": true,
    "InitialDelaySeconds": 45,
    "PollMinutes": 15,
    "MaxItemsPerRun": 40,
    "Sources": [
      {
        "Name": "TuoiTre-RSS-Events",
        "Kind": "Rss",
        "Url": "https://tuoitre.vn/rss/chung-khoan.rss",
        "MaxItems": 22
      },
      {
        "Name": "VietnamNet-RSS-Events",
        "Kind": "Rss",
        "Url": "https://vietnamnet.vn/rss/chung-khoan.rss",
        "MaxItems": 22
      }
    ]
  }
}
